# Copy to .env (or export these) before starting the master and workers.
# Every process reads its Kafka address from KAFKA_BROKER.

# Kafka bootstrap server. Use localhost with the bundled docker-compose,
# or the broker host's IP when master/workers run on separate machines.
KAFKA_BROKER=localhost:9092

# --- Worker only ---
# Unique per worker instance. All workers share CONSUMER_GROUP so Kafka
# load-balances tiles across them; only WORKER_ID must differ.
WORKER_ID=worker-1
CONSUMER_GROUP=image-processors
